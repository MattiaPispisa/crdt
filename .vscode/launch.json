{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "crdt_lf_flutter_example",
      "cwd": "packages/crdt_lf/flutter_example",
      "request": "launch",
      "type": "dart",
      "args": []
    },
    {
      "name": "crdt_lf_devtools_extension",
      "cwd": "packages/crdt_lf_devtools_extension",
      "request": "launch",
      "type": "dart",
      "args": ["--dart-define=use_simulated_environment=true"]
    },
    {
      "name": "crdt_socket_sync: server (example)",
      "cwd": "packages/crdt_socket_sync/example",
      "request": "launch",
      "type": "dart",
      "args": []
    },
    {
      "name": "crdt_socket_sync: client (client_example)",
      "cwd": "packages/crdt_socket_sync/client_example",
      "request": "launch",
      "type": "dart",
      "args": []
    },
    // --- sync-examples demo (persistent server + N clients) ---
    {
      "name": "sync-examples: client 1",
      "cwd": "packages/crdt_socket_sync/client_example",
      "request": "launch",
      "type": "dart",
      "args": [
        "-d",
        "chrome",
        "--web-port",
        "5001",
        "--dart-define=SERVER_URL=ws://localhost:8080"
      ]
    },
    {
      "name": "sync-examples: client 2",
      "cwd": "packages/crdt_socket_sync/client_example",
      "request": "launch",
      "type": "dart",
      "args": [
        "-d",
        "chrome",
        "--web-port",
        "5002",
        "--dart-define=SERVER_URL=ws://localhost:8080"
      ]
    }
  ],
  "compounds": [
    {
      "name": "sync-examples: demo (server + 2 clients)",
      "configurations": [
        "crdt_socket_sync: server (example)",
        "sync-examples: client 1",
        "sync-examples: client 2"
      ]
    }
  ]
}
