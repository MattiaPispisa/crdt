{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "greyhound-markdown-server",
  "main": "src/index.ts",
  "compatibility_date": "2025-07-01",
  "durable_objects": {
    "bindings": [
      {
        "name": "ROOM",
        "class_name": "RoomDO"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["RoomDO"]
    }
  ]
}
